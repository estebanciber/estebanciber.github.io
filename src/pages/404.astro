---
import Base from '../layouts/Base.astro';
import { profile } from '../data/site';

const fonts =
  'https://fonts.googleapis.com/css2?family=Bodoni+Moda:ital,opsz,wght@0,6..96,400;0,6..96,500;0,6..96,700;1,6..96,400;1,6..96,500&family=Jost:wght@300;400;500;600&display=swap';
const base = import.meta.env.BASE_URL;
const home = base.replace(/\/?$/, '/');
---

<Base
  title={`404 — ${profile.name}`}
  themeClass="t-editorial"
  fonts={fonts}
  accent="#9a5034"
>
  <header class="mast">
    <div class="mast__row">
      <a class="logo" href={home}>MJ<em>·</em>Arévalo</a>
    </div>
  </header>

  <main>
    <section class="section not-found">
      <div class="wrap">
        <h1 data-split>Página no encontrada</h1>
        <p data-reveal="up">La página que buscas no existe o fue movida.</p>
        <a data-reveal="up" class="not-found__link" href={home}>Volver al inicio →</a>
      </div>
    </section>
  </main>

  <footer class="foot">
    <div class="foot__row">
      <span>© {profile.year} {profile.name}</span>
      <a class="foot__top" href={home}>Volver al inicio ↑</a>
      <span>Portafolio · {profile.role} · UDLA</span>
    </div>
  </footer>
</Base>

<style lang="scss" is:global>
  @use '../styles/mixins' as *;

  .t-editorial .not-found {
    min-height: 70vh;
    display: flex;
    align-items: center;
    justify-content: center;
    text-align: center;
    .wrap {
      display: flex;
      flex-direction: column;
      align-items: center;
      gap: 1.4rem;
    }
    h1 {
      font-family: var(--serif);
      font-weight: 500;
      font-size: clamp(2.4rem, 3.5vw, 4rem);
      line-height: 1;
    }
    p {
      color: var(--ink-soft);
      font-size: 1.1rem;
    }
  }
  .not-found__link {
    display: inline-flex;
    align-items: center;
    gap: 0.6rem;
    border-bottom: 1.5px solid var(--terra);
    padding-bottom: 0.25rem;
    color: var(--terra-deep);
    font-weight: 500;
    font-size: 0.9rem;
    transition: gap 0.3s ease;
    @include focus-ring(var(--terra));
    &:hover { gap: 1rem; }
  }
</style>
